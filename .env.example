# brb configuration
# Copy to .env and fill in values

# Proxy port
BRB_PORT=3000

# Data directory (auto-created on first run)
BRB_DATA_DIR=./data

# llama.cpp servers
BRB_EMBED_URL=http://localhost:9090
BRB_EXTRACT_URL=http://localhost:9091

# Embedding dimensions (nomic-embed-text = 768)
BRB_EMBED_DIM=768

# Retrieval settings
BRB_MAX_MEMORIES=10
BRB_MIN_SCORE=0.3
BRB_MAX_MEMORY_TOKENS=1500
BRB_DEDUP_THRESHOLD=0.88

# Set to "true" to skip query rewriting (saves ~1s per request)
BRB_NO_REWRITE=false

# Log level: debug, info, warn, error (default: info)
BRB_LOG_LEVEL=info
